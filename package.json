{
  "name": "cf-sim",
  "version": "0.3.0",
  "description": "Visualize your income, expenses, and balance over time",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/*.js",
    "lint:fix": "eslint src/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "jscpd": "jscpd --config .jscpd.json",
    "prepare": "husky",
    "release": "release-please release",
    "docs": "jsdoc2md src/cashflow.js > API.md"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-plugin-boundaries": "^6.0.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "jsdoc-to-markdown": "^9.1.3",
    "knip": "^6.0.4",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "release-please": "^17.3.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
