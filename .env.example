# Cashflow Simulator Environment Variables
#
# This app is a client-side SPA (Single Page Application) with no backend.
# All data is stored in localStorage in the browser.
#
# Environment variables below are for CI/CD and development tooling only.

# Node environment
NODE_ENV=development

# No API keys required - this is a pure client-side application
# All cashflow data is stored locally in the browser's localStorage
